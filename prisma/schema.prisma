generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                String    @id @default(cuid())
  telegramId        String    @unique
  walletAddress     String?
  watchlist         String    @default("[]")  // JSON array
  preferences       String    @default("{}")  // JSON object
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  episodicMemories  EpisodicMemory[]
  semanticMemories  SemanticMemory[]
}

model EpisodicMemory {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])

  eventType       String
  eventPayload    String    // JSON

  reasoningTrace  String
  confidence      Float

  actionType      String?
  actionPayload   String?   // JSON

  userResponse    String?
  executedAt      DateTime?
  executionResult String?   // JSON

  pnl1h           Float?
  pnl24h          Float?
  pnl7d           Float?

  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([eventType])
}

model SemanticMemory {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])

  key             String
  value           String
  confidence      Float
  source          String

  embedding       String?   // JSON array of floats [0.1, 0.2, ...]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, key])
}

model ProcessedEvent {
  id              String    @id @default(cuid())
  eventSignature  String    @unique
  processedAt     DateTime  @default(now())
}
